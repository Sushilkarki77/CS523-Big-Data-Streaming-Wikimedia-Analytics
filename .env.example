# Copy to .env and adjust. Used by producer / Spark (loaded in Docker via mount + python-dotenv).
#
# Kafka advertised listener is kafka-server:9092 inside Docker.
# Host-native producer only: add to hosts file —
#   macOS/Linux: 127.0.0.1 kafka-server  (in /etc/hosts)
#   Windows:     127.0.0.1 kafka-server  (in C:\Windows\System32\drivers\etc\hosts)
# Prefer: bash scripts/run-producer-docker.sh (no hosts change on any OS).

KAFKA_BOOTSTRAP_SERVERS=kafka-server:9092
# Phase 1 fixed topic — must match docs/kafka-message-contract.md
KAFKA_TOPIC_RAW=bdt-wikimedia-recentchange

# Wikimedia EventStreams (SSE); override only if needed
# EVENTSTREAMS_URL=https://stream.wikimedia.org/v2/stream/recentchange

# Inside kafka-server container only (scripts default to localhost:9092)
# KAFKA_BOOTSTRAP_INTERNAL=localhost:9092

# Hive metastore Postgres (reference only; Hive uses metastore via Hive config)
HIVE_METASTORE_DB_HOST=localhost
HIVE_METASTORE_DB_PORT=5432
HIVE_METASTORE_DB_NAME=hive_metastore
HIVE_METASTORE_DB_USER=hive
HIVE_METASTORE_DB_PASSWORD=hivepassword

# Spark Structured Streaming (scripts/run-spark-streaming-hive.sh and scripts/dev/run-spark-streaming-console.sh)
# SPARK_STARTING_OFFSETS=latest
# SPARK_CHECKPOINT_DIR=hdfs://localhost:9000/tmp/wiki-pulse/checkpoints/hive
# SPARK_WINDOW_DURATION=5 minutes
# SPARK_WATERMARK_DELAY=10 minutes
# SPARK_TRIGGER_INTERVAL=30 seconds
# SPARK_SHUFFLE_PARTITIONS=4

# Dashboard export loop (scripts/export-hive-dashboard-loop.sh / start.sh)
# EXPORT_INTERVAL_SECONDS=120
