# Copy to .env and adjust. Used by producer / Spark examples (Phase 1+).
# Phase 0: Kafka advertised listener is kafka-server:9092 — add hosts entry:
#   127.0.0.1 kafka-server

KAFKA_BOOTSTRAP_SERVERS=kafka-server:9092
# Phase 1 fixed topic — must match docs/kafka-message-contract.md
KAFKA_TOPIC_RAW=bdt-wikimedia-recentchange

# Wikimedia EventStreams (SSE); override only if needed
# EVENTSTREAMS_URL=https://stream.wikimedia.org/v2/stream/recentchange

# Inside kafka-server container only (scripts default to localhost:9092)
# KAFKA_BOOTSTRAP_INTERNAL=localhost:9092

# Hive metastore Postgres (reference only; Hive uses metastore via Hive config)
HIVE_METASTORE_DB_HOST=localhost
HIVE_METASTORE_DB_PORT=5432
HIVE_METASTORE_DB_NAME=hive_metastore
HIVE_METASTORE_DB_USER=hive
HIVE_METASTORE_DB_PASSWORD=hivepassword

# Spark checkpoint directory — use HDFS or local path inside lab container when running Spark
# SPARK_CHECKPOINT_DIR=hdfs://localhost:9000/user/$(whoami)/checkpoints
